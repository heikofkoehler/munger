# Data source — set one (checked in this order: Monarch > CSV > Sheets):
# MONARCH_JSON_PATH=monarch_response.json   # path to stored Monarch response
# CSV_PATH=portfolio_holdings.csv
# SHEET_ID=your_google_sheet_id_here

# Monarch Money token (used by monarch.py to fetch fresh data)
# MONARCH_TOKEN=your_token_here

# Google OAuth credentials (only needed for Sheets)
GOOGLE_CREDENTIALS_PATH=credentials.json

# Concentration risk threshold (default: 10.0%)
# CONC_THRESHOLD=10.0
